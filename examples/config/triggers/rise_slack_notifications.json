{
  "rise_access_manager_arb_slack": {
    "name": "RISE Bridge AccessManager Alert (Arbitrum)",
    "trigger_type": "slack",
    "config": {
      "slack_url": {
        "type": "environment",
        "value": "SLACK_WEBHOOK_URL"
      },
      "message": {
        "title": ":lock: ${monitor.name}",
        "body": "*AccessManager Action*\n*Contract:* <https://arbiscan.io/address/${transaction.to}|${transaction.to}>\n*Called by:* <https://arbiscan.io/address/${transaction.from}|${transaction.from}>\n*Tx:* <https://arbiscan.io/tx/${transaction.hash}|${transaction.hash}>\n\n${events}"
      }
    }
  },
